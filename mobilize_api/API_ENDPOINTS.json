        {
          "method": "POST",
          "endpoint": "/reset-password",
          "auth": "JWT",
          "purpose": "Reset/change password for current user"
        },
        {
          "method": "GET",
          "endpoint": "/forgot-password/:email",
          "auth": "none",
          "purpose": "Send forgot password link/OTP to email"
        },
        {
          "method": "PUT",
          "endpoint": "/profile/update/:uid",
          "auth": "JWT",
          "purpose": "Update user profile details by admin"
        },
        {
          "method": "POST",
          "endpoint": "/create/:userType",
          "auth": "JWT",
          "purpose": "Create new user (PUBLISHER/CONSUMER/ADMIN)"
        },
        {
          "method": "GET",
          "endpoint": "/uid/:uid",
