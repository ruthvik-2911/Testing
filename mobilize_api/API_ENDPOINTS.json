      "routes": [
        {
          "method": "GET",
          "endpoint": "/import",
          "auth": "none",
          "purpose": "Import users data (admin function)"
        },
        {
          "method": "POST",
          "endpoint": "/login",
          "auth": "none",
          "purpose": "User login with email/phone and password or OTP"
        },
        {
          "method": "POST",
          "endpoint": "/verify-otp",
          "auth": "none",
          "purpose": "Verify OTP for login/registration"
        },
        {
          "method": "POST",
          "endpoint": "/resend-otp",
          "auth": "none",
          "purpose": "Resend OTP to user"
        },
        {
          "method": "GET",
          "endpoint": "/me",
          "auth": "JWT",
          "purpose": "Get current authenticated user profile"
        },
        {
          "method": "PUT",
          "endpoint": "/update",
          "auth": "JWT + UserGuard",
          "purpose": "Complete/update current user profile"
