# Firebase Configuration
# Get these values from your Firebase project settings
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=your-app-id

# JWT Secret for custom token generation
# In production, use a strong, randomly generated secret
VITE_JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Backend URLs
VITE_ADMIN_BACKEND_URL=http://localhost:8080
VITE_AD_MOBILE_BACKEND_URL=https://your-ad-mobile-api.com

# Optional: Ad Mobile API Token (if required)
VITE_AD_MOBILE_TOKEN=your-ad-mobile-token
